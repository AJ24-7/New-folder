# Copy this file to .env and fill in real values.
RAZORPAY_PAYMENT_LINK=YOUR_RAZORPAY_PAYMENT_LINK_HERE

# ── SMTP / Email ────────────────────────────────────────────────────────────
# Hostinger (and most cloud-SMTP providers) support two connection modes:
#   Port 587  – STARTTLS  (preferred on cloud hosts like Render — port 465 is
#               often blocked, causing ETIMEDOUT on CONN errors)
#   Port 465  – Implicit SSL (set SMTP_SECURE=true if you use this port)
#
# Recommended Render-safe settings:
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
# Leave SMTP_SECURE unset (or set to false) when using port 587 (STARTTLS).
# Set SMTP_SECURE=true only when using port 465 (implicit SSL).
# SMTP_SECURE=false

# Credentials for the sending mailbox
SMTP_AUTH_USER=support@gym-wale.com
SMTP_AUTH_PASS=YOUR_EMAIL_PASSWORD_HERE

# Optional overrides
# SUPPORT_EMAIL=support@gym-wale.com
# FROM_EMAIL=support@gym-wale.com
# MAIL_FORCE_FROM=support@gym-wale.com
# BRAND_FROM_NAME=Gym-Wale
